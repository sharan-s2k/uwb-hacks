POSTGRES_DB=civicfix
POSTGRES_USER=civicfix
POSTGRES_PASSWORD=changeme

# Must match the credentials above
DATABASE_URL=postgresql://civicfix:changeme@localhost:5432/civicfix

# Auth0 (not required for local dev — backend uses header-based stub auth)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.civicfix.local
AUTH0_CLIENT_ID=your_client_id

# Ollama / Gemma (local LLM for AI triage)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b

# ElevenLabs Conversational AI
# Create an agent at https://elevenlabs.io/app/conversational-ai
# and paste the Agent ID here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
