# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=civicfix
POSTGRES_USER=civicfix
POSTGRES_PASSWORD=changeme

# Must stay in sync with the three values above
DATABASE_URL=postgresql://civicfix:changeme@localhost:5432/civicfix

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Not required for local dev — backend auto-creates a citizen user via stub auth
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.civicfix.local
AUTH0_CLIENT_ID=your_auth0_client_id

# ── Ollama / Gemma (local AI triage) ─────────────────────────────────────────
# Run `ollama serve` locally, then `ollama pull gemma3:4b`
# When running inside Docker use host.docker.internal; for local dev use localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── ElevenLabs Conversational AI ─────────────────────────────────────────────
# 1. Go to https://elevenlabs.io/app/conversational-ai
# 2. Create an agent with the CivicFix system prompt (see README)
# 3. Paste the Agent ID below
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Leave empty when using the monolith Docker image (nginx proxies /api → backend)
# Set to http://localhost:8000 when running frontend and backend separately
NEXT_PUBLIC_API_URL=
